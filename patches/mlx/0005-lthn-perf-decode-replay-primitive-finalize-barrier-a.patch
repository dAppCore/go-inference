From: Snider <snider@host.uk.com>
Date: Tue, 16 Jun 2026 17:59:40 +0100
Subject: [PATCH 05/10] =?UTF-8?q?lthn(perf):=20decode=20replay=20primitive?=
 =?UTF-8?q?=20=E2=80=94=20finalize=20+=20barrier-aware=20re-issue=20of=20t?=
 =?UTF-8?q?he=20recorded=20command=20stream?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

lthn_decode_finalize() stashes one decode step's recorded command stream; lthn_decode_replay(raw) re-issues it (pipeline/binds/bytes/tg-mem/dispatch + captured memoryBarriers) directly to the compute encoder, bypassing the MLX tape-walk + per-primitive eval_gpu (~12ms host/token). Guarded by lthn_decode_replaying so replay doesn't re-record. Not yet wired into the decode loop (needs buffer pinning + input/offset update + byte-exact gate). Dark by default (env MLX_DECODE_CAPTURE).

Co-Authored-By: Virgil <virgil@lethean.io>
---
 mlx/backend/metal/device.cpp | 58 +++++++++++++++++++++++++++++++++++-
 mlx/backend/metal/device.h   |  7 +++++
 2 files changed, 64 insertions(+), 1 deletion(-)

diff --git a/mlx/backend/metal/device.cpp b/mlx/backend/metal/device.cpp
index a45fc5c1..f298d234 100644
--- a/mlx/backend/metal/device.cpp
+++ b/mlx/backend/metal/device.cpp
@@ -318,6 +318,7 @@ struct LthnRecCmd {
   MTL::Size grid{0, 0, 0};
   MTL::Size group{0, 0, 0};
   bool threadgroups = false;
+  bool barrier_before = false; // a memoryBarrier preceded this dispatch
 };
 inline bool lthn_capture_env() {
   static const bool on = [] {
@@ -336,9 +337,16 @@ inline void lthn_rec_flush_cur() {
     lthn_rec_cur_open = false;
   }
 }
+thread_local bool lthn_pending_barrier = false;
+// The finalised replay program — one decode step's full command stream — and a
+// guard so re-issuing it doesn't recursively re-record.
+thread_local std::vector<LthnRecCmd> lthn_replay_program;
+thread_local bool lthn_decode_replaying = false;
 } // namespace
 
-bool lthn_decode_recording() { return lthn_capture_env(); }
+bool lthn_decode_recording() {
+  return lthn_capture_env() && !lthn_decode_replaying;
+}
 void lthn_decode_rec_pipeline(MTL::ComputePipelineState* kernel) {
   lthn_rec_flush_cur(); // a new pipeline-set begins a new command
   lthn_rec_cur.pipeline = kernel;
@@ -358,6 +366,47 @@ void lthn_decode_rec_tgmem(size_t length, int idx) {
   lthn_rec_cur.tgmem.emplace_back(length, idx);
 }
 
+// Finalise the current recording into the replay program (one decode step's full
+// command stream). Returns the command count.
+size_t lthn_decode_finalize() {
+  lthn_rec_flush_cur();
+  lthn_replay_program = std::move(lthn_rec_cmds);
+  lthn_rec_cmds.clear();
+  return lthn_replay_program.size();
+}
+
+// Re-issue the recorded command stream directly to the raw compute encoder,
+// bypassing the MLX tape-walk + per-primitive eval_gpu (the ~12 ms host cost).
+// Buffers must still be valid — the caller pins the step's buffers. The replaying
+// guard keeps lthn_decode_recording() false so this doesn't recursively re-record.
+void lthn_decode_replay(MTL::ComputeCommandEncoder* raw) {
+  if (raw == nullptr) {
+    return;
+  }
+  lthn_decode_replaying = true;
+  for (auto& c : lthn_replay_program) {
+    if (c.barrier_before) {
+      raw->memoryBarrier(MTL::BarrierScopeBuffers);
+    }
+    raw->setComputePipelineState(c.pipeline);
+    for (auto& b : c.buffers) {
+      raw->setBuffer(std::get<0>(b), std::get<1>(b), std::get<2>(b));
+    }
+    for (auto& by : c.bytes) {
+      raw->setBytes(by.first.data(), by.first.size(), by.second);
+    }
+    for (auto& tg : c.tgmem) {
+      raw->setThreadgroupMemoryLength(tg.first, tg.second);
+    }
+    if (c.threadgroups) {
+      raw->dispatchThreadgroups(c.grid, c.group);
+    } else {
+      raw->dispatchThreads(c.grid, c.group);
+    }
+  }
+  lthn_decode_replaying = false;
+}
+
 void CommandEncoder::set_buffer(
     const MTL::Buffer* buf,
     int idx,
@@ -424,6 +473,9 @@ void CommandEncoder::maybeInsertBarrier() {
   if (needs_barrier_) {
     get_command_encoder()->memoryBarrier(MTL::BarrierScopeBuffers);
     needs_barrier_ = false;
+    if (lthn_capture_env()) {
+      lthn_pending_barrier = true;
+    }
     prev_outputs_ = std::move(next_outputs_);
   } else {
     prev_outputs_.insert(next_outputs_.begin(), next_outputs_.end());
@@ -440,6 +492,8 @@ void CommandEncoder::dispatch_threadgroups(
     lthn_rec_cur.grid = grid_dims;
     lthn_rec_cur.group = group_dims;
     lthn_rec_cur.threadgroups = true;
+    lthn_rec_cur.barrier_before = lthn_pending_barrier;
+    lthn_pending_barrier = false;
     lthn_rec_flush_cur();
   }
   get_command_encoder()->dispatchThreadgroups(grid_dims, group_dims);
@@ -454,6 +508,8 @@ void CommandEncoder::dispatch_threads(
     lthn_rec_cur.grid = grid_dims;
     lthn_rec_cur.group = group_dims;
     lthn_rec_cur.threadgroups = false;
+    lthn_rec_cur.barrier_before = lthn_pending_barrier;
+    lthn_pending_barrier = false;
     lthn_rec_flush_cur();
   }
   get_command_encoder()->dispatchThreads(grid_dims, group_dims);
diff --git a/mlx/backend/metal/device.h b/mlx/backend/metal/device.h
index 2f2a8136..a77674ae 100644
--- a/mlx/backend/metal/device.h
+++ b/mlx/backend/metal/device.h
@@ -27,6 +27,8 @@ bool lthn_decode_recording();
 void lthn_decode_rec_pipeline(MTL::ComputePipelineState* kernel);
 void lthn_decode_rec_bytes(const void* data, size_t nbytes, int idx);
 void lthn_decode_rec_tgmem(size_t length, int idx);
+size_t lthn_decode_finalize();
+void lthn_decode_replay(MTL::ComputeCommandEncoder* raw);
 
 class Device;
 
@@ -125,6 +127,11 @@ class MLX_API CommandEncoder {
   MTL::CommandBuffer* get_command_buffer() const {
     return buffer_.get();
   }
+  // lthn decode replay: public access to the underlying compute encoder so the
+  // replay path can re-issue recorded commands directly (creates it if needed).
+  MTL::ComputeCommandEncoder* lthn_raw_encoder() {
+    return get_command_encoder();
+  }
 
  private:
   MTL::ComputeCommandEncoder* get_command_encoder();
-- 
