lthn_decode_replay_step(s) re-issues the captured step program to the stream's encoder and commits per command buffer, bypassing the MLX tape-walk + eval_gpu. With the recorder, step-capture, and pin, the C++ replay machinery is complete; next is the cgo bridge + decode-loop hook to drive record-once / replay-rest with the input+offset buffer updates and a byte-exact gate.

Co-Authored-By: Virgil <virgil@lethean.io>
---
 mlx/backend/metal/device.cpp | 38 ++++++++++++++++++++++++++++++++++++
 mlx/backend/metal/device.h   |  1 +
 2 files changed, 39 insertions(+)

diff --git a/mlx/backend/metal/device.cpp b/mlx/backend/metal/device.cpp
index 3e33c650..c9447bce 100644
--- a/mlx/backend/metal/device.cpp
+++ b/mlx/backend/metal/device.cpp
@@ -428,6 +428,44 @@ size_t lthn_decode_step_end() {
   return lthn_step_program.size();
 }
 
+// Replay a captured decode step on stream `s`: re-issue each command buffer's
+// recorded stream to the encoder, committing per CB (queue order preserves the
+// cross-CB dependency the original commits encoded), then wait for completion.
+// Bypasses the MLX tape-walk + per-primitive eval_gpu (the ~12 ms host cost).
+// The step's buffers must still be valid — the caller pins them; per-token state
+// (input token, cache offset) is written into those pinned buffers before replay.
+void lthn_decode_replay_step(Stream s) {
+  auto& enc = get_command_encoder(s);
+  lthn_decode_replaying = true;
+  for (auto& cb : lthn_step_program) {
+    auto* raw = enc.lthn_raw_encoder();
+    for (auto& c : cb) {
+      if (c.barrier_before) {
+        raw->memoryBarrier(MTL::BarrierScopeBuffers);
+      }
+      raw->setComputePipelineState(c.pipeline);
+      for (auto& b : c.buffers) {
+        raw->setBuffer(std::get<0>(b), std::get<1>(b), std::get<2>(b));
+      }
+      for (auto& by : c.bytes) {
+        raw->setBytes(by.first.data(), by.first.size(), by.second);
+      }
+      for (auto& tg : c.tgmem) {
+        raw->setThreadgroupMemoryLength(tg.first, tg.second);
+      }
+      if (c.threadgroups) {
+        raw->dispatchThreadgroups(c.grid, c.group);
+      } else {
+        raw->dispatchThreads(c.grid, c.group);
+      }
+    }
+    enc.end_encoding();
+    enc.commit();
+  }
+  enc.synchronize();
+  lthn_decode_replaying = false;
+}
+
 void CommandEncoder::set_buffer(
     const MTL::Buffer* buf,
     int idx,
diff --git a/mlx/backend/metal/device.h b/mlx/backend/metal/device.h
index 23350c84..c0ed074d 100644
--- a/mlx/backend/metal/device.h
+++ b/mlx/backend/metal/device.h
@@ -33,6 +33,7 @@ void lthn_decode_pin_begin();
 void lthn_decode_pin_release();
 void lthn_decode_step_begin();
 size_t lthn_decode_step_end();
+void lthn_decode_replay_step(Stream s);
 
 class Device;
 
